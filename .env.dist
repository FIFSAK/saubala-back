APP_MODE='dev'
APP_PORT='80'
APP_PATH='/api/v1'
APP_TIMEOUT='60s'

HTTP_PORT=':8080'

# Браузерные origin'ы фронтенда. '*' — любой (для локальной разработки).
# В проде укажите список через запятую, напр.: https://app.saubala.kz
CORS_ALLOWED_ORIGINS='*'

MONGO_URI='mongodb://localhost:27017'
MONGO_DB='saubala'

JWT_SECRET='change-me'
JWT_ACCESS_TTL='24h'

SUPERADMIN_EMAIL='admin@saubala.kz'
SUPERADMIN_PASSWORD='change-me'
